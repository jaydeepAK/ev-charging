# Copy this file to .env and fill in real values. Never commit .env itself.

# Supabase gives you 3 connection strings under Project Settings > Database > Connect.
# Render (and many hosts) can't reach the direct db.<ref>.supabase.co host — it's
# IPv6-only. Use the POOLER strings instead, which are IPv4-reachable:

# "Transaction pooler" string, port 6543 — used for normal app queries
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# "Session pooler" string, port 5432 — same pooler host, different port/mode.
# Needed only for running migrations (pooled/transaction mode doesn't support
# the session features `prisma migrate` relies on).
DIRECT_URL="postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# Any long random string. Used to sign/verify JWTs — treat it like a password.
JWT_SECRET="replace-with-a-long-random-string"

PORT=5000
