# Copy this file to .env and fill in real values. Never commit .env itself.

# Get this from whichever free Postgres host you pick (Day 2 topic).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/ev_charging"

# Any long random string. Used to sign/verify JWTs — treat it like a password.
JWT_SECRET="replace-with-a-long-random-string"

PORT=5000
